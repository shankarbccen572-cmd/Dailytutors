# --- MongoDB ---
# Local: mongodb://127.0.0.1:27017/perspective-learning
# Atlas: mongodb+srv://<user>:<pass>@<cluster>/perspective-learning
MONGODB_URI=mongodb://127.0.0.1:27017/perspective-learning

# --- NextAuth ---
NEXTAUTH_URL=http://localhost:3000
# Generate with:  openssl rand -base64 32
NEXTAUTH_SECRET=

# --- Google OAuth (from Google Cloud Console) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated emails granted the "admin" role on first sign-in
ADMIN_EMAILS=

# Comma-separated emails granted the "faculty" role on first sign-in
# (faculty can log into the admin panel to create courses, quizzes & questions)
FACULTY_EMAILS=

# Skip Google login during development (buttons go straight to /dashboard)
NEXT_PUBLIC_DISABLE_AUTH=true

# --- Cloudinary (unsigned upload for course thumbnails) ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# --- MSG91 OTP Widget (popup flow) ---
# The widget sends & verifies the OTP in the browser, then returns an
# access-token. These two are public (used by the widget in the browser):
NEXT_PUBLIC_MSG91_WIDGET_ID=
NEXT_PUBLIC_MSG91_TOKEN_AUTH=
# Server-only: used ONLY to verify the widget access-token (verifyAccessToken).
# Never exposed to the browser. No MSG91_TEMPLATE_ID / REST OTP API is used.
MSG91_AUTH_KEY=

# --- Razorpay Payment Gateway ---
# Public key exposed to the browser for checkout initialization.
NEXT_PUBLIC_RAZORPAY_KEY_ID=
# Server-only keys used to create orders and verify signatures.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
